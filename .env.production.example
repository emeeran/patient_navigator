# ── Patient Navigator — Production Environment ────────
# Copy this file to .env.production and fill in all values.
#
# Generate secrets with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# ── Application ──────────────────────────────────────
ENVIRONMENT=production
APP_NAME="Patient Navigator"
APP_VERSION=0.1.0
DEBUG=false

# ── Database ─────────────────────────────────────────
# Used by docker-compose.prod.yml — must match POSTGRES_PASSWORD
POSTGRES_PASSWORD=<generate-a-strong-password>
DATABASE_URL=postgresql+asyncpg://navigator:${POSTGRES_PASSWORD}@db:5432/patient_nav
DATABASE_URL_SYNC=postgresql://navigator:${POSTGRES_PASSWORD}@db:5432/patient_nav

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── JWT Authentication ──────────────────────────────
# MUST be changed — the default value is rejected in production
JWT_SECRET_KEY=<generate-with-command-above>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Security ─────────────────────────────────────────
BCRYPT_ROUNDS=12
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600

# ── CORS ─────────────────────────────────────────────
# Comma-separated origins — no wildcards or localhost in production
CORS_ORIGINS=https://yourdomain.com

# ── File Uploads ─────────────────────────────────────
UPLOAD_DIR=./uploads/documents
MAX_UPLOAD_SIZE_BYTES=26214400

# ── AI / LLM ─────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
DEFAULT_MODEL=medgemma:4b
OLLAMA_TIMEOUT=60
