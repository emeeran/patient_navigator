# ── Application ──────────────────────────────────────
APP_NAME=Patient Navigator
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://navigator:navigator_dev@localhost:5432/patient_nav
DATABASE_URL_SYNC=postgresql://navigator:navigator_dev@localhost:5432/patient_nav

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ──────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-min-32-chars!!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Security ─────────────────────────────────────────
BCRYPT_ROUNDS=12
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=600

# ── CORS ─────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
