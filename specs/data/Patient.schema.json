{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://patient-navigator.com/schemas/Patient.schema.json",

  "x-spec-id": "DATA-003",
  "x-status": "DRAFT",
  "x-version": "1.0.0",
  "x-authors": ["@platform-team"],
  "x-created": "2026-06-04",
  "x-last-modified": "2026-06-04",
  "x-relates-to": ["API-010", "API-011", "API-012", "API-013", "API-014", "API-090"],

  "title": "Patient",
  "description": "A patient record in the care coordination system. Contains personal information, emergency contacts, and assignment metadata. Patients are created by navigators/admins and linked to cases for care tracking. PII fields are encrypted at rest and masked based on viewer role.",

  "type": "object",
  "required": ["id", "fullName", "age", "gender", "status", "createdBy", "createdAt", "updatedAt"],
  "additionalProperties": false,

  "properties": {

    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Globally unique identifier (UUID v4). Assigned by the system on creation.",
      "examples": ["770e8400-e29b-41d4-a716-446655440002"],
      "readOnly": true
    },

    "fullName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^\\S.*\\S$|^\\S$",
      "description": "Patient's full legal name. Supports Unicode characters for multilingual names.",
      "examples": ["Aarav Mehta", "José García-López"],
      "x-pii": true,
      "x-encryption": "at-rest",
      "x-search-index": "gin-trigram"
    },

    "age": {
      "type": "integer",
      "minimum": 0,
      "maximum": 150,
      "description": "Patient's age in years. Validated to be between 0 and 150 inclusive.",
      "examples": [45, 0, 72]
    },

    "gender": {
      "type": "string",
      "enum": ["male", "female", "other", "prefer_not_to_say"],
      "description": "Patient's self-reported gender identity.",
      "examples": ["male", "female", "other", "prefer_not_to_say"]
    },

    "phone": {
      "type": ["string", "null"],
      "pattern": "^\\+?[0-9]{7,20}$",
      "maxLength": 20,
      "description": "Contact phone number in E.164-ish format (optional).",
      "examples": ["+919876543210"],
      "default": null,
      "x-pii": true,
      "x-encryption": "at-rest",
      "x-masking": {
        "navigator": "full",
        "admin": "full",
        "clinician": "partial",
        "volunteer": "full-mask",
        "patient": "own-only"
      }
    },

    "email": {
      "type": ["string", "null"],
      "format": "email",
      "maxLength": 254,
      "description": "Patient's email address (optional).",
      "examples": ["aarav.mehta@example.org"],
      "default": null,
      "x-pii": true,
      "x-encryption": "at-rest",
      "x-masking": {
        "navigator": "full",
        "admin": "full",
        "clinician": "partial",
        "volunteer": "full-mask",
        "patient": "own-only"
      }
    },

    "address": {
      "type": ["string", "null"],
      "maxLength": 1000,
      "description": "Patient's residential address (optional).",
      "default": null,
      "x-pii": true,
      "x-encryption": "at-rest"
    },

    "emergencyContactName": {
      "type": ["string", "null"],
      "maxLength": 255,
      "description": "Name of the patient's emergency contact person.",
      "examples": ["Priya Mehta"],
      "default": null,
      "x-pii": true,
      "x-encryption": "at-rest"
    },

    "emergencyContactPhone": {
      "type": ["string", "null"],
      "pattern": "^\\+?[0-9]{7,20}$",
      "maxLength": 20,
      "description": "Phone number of the patient's emergency contact.",
      "examples": ["+919876543211"],
      "default": null,
      "x-pii": true,
      "x-encryption": "at-rest"
    },

    "navigatorId": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "ID of the User (navigator) assigned to this patient. Null if unassigned.",
      "examples": ["660e8400-e29b-41d4-a716-446655440001"],
      "default": null,
      "x-foreign-key": "User.id",
      "x-on-delete": "SET NULL"
    },

    "status": {
      "type": "string",
      "enum": ["active", "inactive", "archived"],
      "default": "active",
      "description": "Patient lifecycle status. Active patients appear in default queries. Archived patients are soft-deleted.",
      "x-transitions": {
        "active": ["inactive", "archived"],
        "inactive": ["active", "archived"],
        "archived": []
      }
    },

    "notes": {
      "type": ["string", "null"],
      "maxLength": 10000,
      "description": "Free-text notes about the patient. Visible to navigator+ roles.",
      "default": null
    },

    "createdBy": {
      "type": "string",
      "format": "uuid",
      "description": "ID of the User who created this patient record.",
      "x-foreign-key": "User.id",
      "x-on-delete": "RESTRICT",
      "readOnly": true
    },

    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of when this patient was created.",
      "readOnly": true
    },

    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of last modification.",
      "readOnly": true
    },

    "deletedAt": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "Soft-delete timestamp. Null if active. Set when status transitions to 'archived'.",
      "default": null,
      "readOnly": true
    }

  },

  "x-database-indexes": [
    {"name": "idx_patients_status", "columns": ["status"]},
    {"name": "idx_patients_navigator", "columns": ["navigatorId"]},
    {"name": "idx_patients_full_name_trgm", "columns": ["fullName"], "method": "GIN", "opclass": "gin_trgm_ops"}
  ],

  "examples": [
    {
      "id": "770e8400-e29b-41d4-a716-446655440002",
      "fullName": "Aarav Mehta",
      "age": 45,
      "gender": "male",
      "phone": "+919876543210",
      "email": "aarav.mehta@example.org",
      "address": "42, Anna Nagar, Chennai 600040",
      "emergencyContactName": "Priya Mehta",
      "emergencyContactPhone": "+919876543211",
      "navigatorId": "660e8400-e29b-41d4-a716-446655440001",
      "status": "active",
      "notes": "Referred from Government General Hospital",
      "createdBy": "660e8400-e29b-41d4-a716-446655440001",
      "createdAt": "2026-06-04T10:00:00.000Z",
      "updatedAt": "2026-06-04T10:00:00.000Z",
      "deletedAt": null
    }
  ]
}
