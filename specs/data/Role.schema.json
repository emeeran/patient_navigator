{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://patient-navigator.com/schemas/Role.schema.json",

  "x-spec-id": "DATA-001",
  "x-status": "DRAFT",
  "x-version": "1.0.0",
  "x-authors": ["@platform-team"],
  "x-created": "2026-06-04",
  "x-last-modified": "2026-06-04",
  "x-relates-to": ["API-001", "API-002", "API-003", "API-004", "API-005"],

  "title": "Role",
  "description": "Defines a user role within the Patient Navigator Platform. Each role carries a JSONB permissions map that controls access to resource domains. Five seed roles are provisioned at deployment: admin, navigator, clinician, volunteer, and patient. Roles are immutable after creation (no UPDATE/DELETE) — permission changes require a new role.",

  "type": "object",
  "required": ["id", "name", "permissions", "createdAt", "updatedAt"],
  "additionalProperties": false,

  "properties": {

    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Globally unique identifier (UUID v4). Assigned by the system on creation.",
      "examples": ["a1b2c3d4-e5f6-7890-abcd-ef1234567890"],
      "readOnly": true
    },

    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "pattern": "^[a-z][a-z0-9_-]*$",
      "description": "Machine-readable role name. Must be unique. Lowercase alphanumeric with hyphens/underscores. Allowed values: admin, navigator, clinician, volunteer, patient.",
      "examples": ["admin", "navigator", "clinician", "volunteer", "patient"]
    },

    "description": {
      "type": ["string", "null"],
      "maxLength": 500,
      "description": "Human-readable description of the role's purpose and typical responsibilities.",
      "examples": ["Full system access including user management and audit logs"]
    },

    "permissions": {
      "type": "object",
      "description": "Permission map keyed by resource domain. Each value is an access level: 'full', 'read', 'own', 'review', or 'none'.",
      "additionalProperties": {
        "type": "string",
        "enum": ["full", "read", "own", "review", "none"]
      },
      "properties": {
        "patients": {
          "type": "string",
          "enum": ["full", "read", "own", "review", "none"],
          "description": "Access level for patient records."
        },
        "cases": {
          "type": "string",
          "enum": ["full", "read", "own", "review", "none"],
          "description": "Access level for case management."
        },
        "documents": {
          "type": "string",
          "enum": ["full", "read", "own", "review", "none"],
          "description": "Access level for document upload, OCR, and download."
        },
        "hospitals": {
          "type": "string",
          "enum": ["full", "read", "own", "review", "none"],
          "description": "Access level for hospital directory."
        },
        "funding": {
          "type": "string",
          "enum": ["full", "read", "own", "review", "none"],
          "description": "Access level for funding programs."
        },
        "followups": {
          "type": "string",
          "enum": ["full", "read", "own", "review", "none"],
          "description": "Access level for follow-up tracking."
        },
        "ai": {
          "type": "string",
          "enum": ["full", "read", "own", "review", "none"],
          "description": "Access level for AI medical summaries and clinician review."
        },
        "reports": {
          "type": "string",
          "enum": ["full", "read", "own", "review", "none"],
          "description": "Access level for dashboard reports."
        },
        "users": {
          "type": "string",
          "enum": ["full", "read", "own", "review", "none"],
          "description": "Access level for user management."
        },
        "audit": {
          "type": "string",
          "enum": ["full", "read", "own", "review", "none"],
          "description": "Access level for audit log viewing."
        }
      },
      "x-default-values": {
        "admin": {
          "patients": "full", "cases": "full", "documents": "full", "hospitals": "full",
          "funding": "full", "followups": "full", "ai": "full", "reports": "full",
          "users": "full", "audit": "full"
        },
        "navigator": {
          "patients": "full", "cases": "full", "documents": "full", "hospitals": "read",
          "funding": "read", "followups": "full", "ai": "full", "reports": "read",
          "users": "none", "audit": "none"
        },
        "clinician": {
          "patients": "read", "cases": "read", "documents": "read", "hospitals": "read",
          "funding": "read", "followups": "read", "ai": "review", "reports": "read",
          "users": "none", "audit": "none"
        },
        "volunteer": {
          "patients": "read", "cases": "read", "documents": "none", "hospitals": "read",
          "funding": "read", "followups": "read", "ai": "none", "reports": "none",
          "users": "none", "audit": "none"
        },
        "patient": {
          "patients": "own", "cases": "own", "documents": "own", "hospitals": "read",
          "funding": "read", "followups": "own", "ai": "own", "reports": "own",
          "users": "none", "audit": "none"
        }
      }
    },

    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of when this role was created.",
      "examples": ["2026-06-04T10:00:00.000Z"],
      "readOnly": true
    },

    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of last modification.",
      "examples": ["2026-06-04T10:00:00.000Z"],
      "readOnly": true
    }

  },

  "examples": [
    {
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "name": "admin",
      "description": "Full system access including user management and audit logs",
      "permissions": {
        "patients": "full", "cases": "full", "documents": "full", "hospitals": "full",
        "funding": "full", "followups": "full", "ai": "full", "reports": "full",
        "users": "full", "audit": "full"
      },
      "createdAt": "2026-06-04T10:00:00.000Z",
      "updatedAt": "2026-06-04T10:00:00.000Z"
    },
    {
      "id": "b2c3d4e5-f6a7-8901-bcde-f12345678901",
      "name": "navigator",
      "description": "Patient coordinator with full access to patients, cases, documents, and follow-ups",
      "permissions": {
        "patients": "full", "cases": "full", "documents": "full", "hospitals": "read",
        "funding": "read", "followups": "full", "ai": "full", "reports": "read",
        "users": "none", "audit": "none"
      },
      "createdAt": "2026-06-04T10:00:00.000Z",
      "updatedAt": "2026-06-04T10:00:00.000Z"
    }
  ]
}
